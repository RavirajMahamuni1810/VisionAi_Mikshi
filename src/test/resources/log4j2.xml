<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="INFO" monitorInterval="30">
    <Appenders>

        <!-- Console output -->
        <Console name="Console" target="SYSTEM_OUT">
            <PatternLayout pattern="[%d{HH:mm:ss.SSS}] [%X{threadLabel:-MAIN}] %-5level %logger{36} - %msg%n"/>
        </Console>

        <!-- Dynamic file routing based on logFilePath with fallback -->
        <Routing name="Routing">
            <Routes pattern="$${ctx:logFileName}">
                <Route key="^$">
                    <!-- Default route when logFileName is empty or not set -->
                    <File name="DefaultFile"
                          fileName="logs/application.log"
                          append="false">
                        <PatternLayout pattern="[%d{yyyy-MM-dd HH:mm:ss.SSS}] [%X{threadLabel:-MAIN}] %-5level - %msg%n"/>
                    </File>
                </Route>
                <Route key=".*">
                    <!-- Route when logFileName context variable is set (catch-all) -->
                    <File name="DynamicFile"
                          fileName="${ctx:logFileName}"
                          append="false">
                        <PatternLayout pattern="[%d{yyyy-MM-dd HH:mm:ss.SSS}] [%X{threadLabel:-MAIN}] %-5level - %msg%n"/>
                    </File>
                </Route>
            </Routes>
        </Routing>

    </Appenders>

    <Loggers>
        <Root level="info">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="Routing"/>
        </Root>
    </Loggers>
</Configuration>
